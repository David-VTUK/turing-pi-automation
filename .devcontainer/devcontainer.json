{
	"name": "ansible-env",
	"build": {"dockerfile": "Dockerfile"},
	"customizations": {
		"vscode": {
			"settings": {},
			"extensions": [
				"streetsidesoftware.code-spell-checker",
				"redhat.ansible",
				"redhat.vscode-yaml",
				"ms-python.python"
			]
		}
	},

	"workspaceFolder": "/workspace",
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,Z"
}